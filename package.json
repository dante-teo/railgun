{
  "name": "@dantea/railgun",
  "version": "0.3.3",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dante-teo/railgun.git"
  },
  "bin": {
    "railgun": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "pnpm --filter @dantea/railgun-desktop start",
    "dev:mock": "pnpm --filter @dantea/railgun-desktop start:mock",
    "start": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node -e \"const fs=require('fs');const f='dist/cli.js';const s=fs.readFileSync(f,'utf8');if(!s.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+s);fs.chmodSync(f,0o755)\"",
    "test": "vitest run src",
    "smoke:package": "node scripts/smoke-package.mjs",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run smoke:package"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@huggingface/transformers": "^4.2.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "cron-parser": "^5.6.1",
    "duck-duck-scrape": "^2.2.7",
    "ink": "^6.8.0",
    "ink-multiline-input": "^0.1.0",
    "ink-spinner": "^5.0.0",
    "ipaddr.js": "^2.4.0",
    "jsdom": "^29.1.1",
    "markdansi": "^0.3.2",
    "os-theme": "^0.0.9",
    "react": "^19.2.0",
    "sqlite-vec": "^0.1.9",
    "undici": "^8.7.0",
    "widevin": "^0.1.3",
    "write-file-atomic": "^6.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.17.10",
    "@types/react": "^19.2.0",
    "@types/write-file-atomic": "^4.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.3.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
