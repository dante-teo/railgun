{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "paths": { "@railgun/core/*": ["../../src/*"] },
    "outDir": "dist",
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["renderer/**/*", "gateway/**/*"]
}
