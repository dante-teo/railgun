{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2024"],
    "paths": { "@railgun/core/*": ["../../src/*"] },
    "outDir": "dist",
    "skipLibCheck": true,
    "types": ["bun"]
  },
  "include": ["src/bun/**/*"]
}
