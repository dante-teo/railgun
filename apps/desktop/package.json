{
  "name": "@dantea/railgun-desktop",
  "productName": "Railgun Classic",
  "version": "0.5.0",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "start:mock": "RAILGUN_DESKTOP_BACKEND_MODE=mock electron-forge start",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "build:mock-backend": "vite build --config vite.mock.config.ts",
    "build:backend-assets": "node scripts/build-backend.mjs",
    "build": "pnpm run package",
    "package": "pnpm run build:backend-assets && electron-forge package",
    "make": "pnpm run build:backend-assets && electron-forge make"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.6.1",
    "cronstrue": "^3.24.0",
    "lucide-react": "^1.24.0",
    "overlayscrollbars": "^2.16.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "update-electron-app": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron-forge/publisher-github": "7.11.2",
    "@electron-forge/shared-types": "7.11.2",
    "@electron/fuses": "^2.1.3",
    "@electron/rebuild": "4.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.17.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-core": "^4.12.1",
    "electron": "43.1.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "8.1.4",
    "vitest": "^4.1.10"
  }
}
